# OVDeploy + VocabGuard paths — copy to config/paths.yaml and edit.
# Single-repo layout: project_root and ovdeploy_root both ".".
# Requires: LVIS minival JSON, COCO val2017, YOLO-World v2-S weights.
# See docs/SETUP.md

# OVDeploy — paths (YOLO-World / LVIS read-only from 论文1)
project_root: "."
project_root_wsl: "/path/to/ovdeploy"

yolo_root: "/path/to/YOLO-World"
yolo_root_wsl: "/mnt/d/path/to/YOLO-World"
# WSL native copy of stratified-1k val2017 (see scripts/wsl_stage_val2017_cache.sh)
val2017_cache_wsl: "/home/a/data/coco/val2017"
paper1_project: "/path/to/optional/assets"

data:
  lvis_minival_ann: "data/coco/lvis/lvis_v1_minival_inserted_image_name.json"
  lvis_train_ann: "data/coco/lvis/lvis_v1_train.json"
  val2017_dir: "data/coco/val2017"
  class_texts: "data/texts/lvis_v1_class_texts.json"

weights:
  yolo_world_v2_s: "weights/yolo_world_v2_s_obj365v1_goldg_pretrain-55b943ea.pth"
  yolo_world_v2_m: "weights/yolo_world_v2_m_obj365v1_goldg_pretrain-c6237d5b.pth"
  yolo_world_v2_l: "weights/yolo_world_v2_l_obj365v1_goldg_pretrain-a82b1fe3.pth"
  yolo_world_v2_x: "weights/yolo_world_v2_x_obj365v1_goldg_cc3mlite_pretrain-8698fbfa.pth"

config:
  eval_8gb: "configs/pretrain/yolo_world_v2_s_lvis_minival_8gb.py"
  eval_8gb_m: "configs/pretrain/yolo_world_v2_m_lvis_minival_8gb.py"
  eval_8gb_l: "configs/pretrain/yolo_world_v2_l_lvis_minival_8gb.py"
  eval_8gb_x: "configs/pretrain/yolo_world_v2_x_lvis_minival_8gb.py"

reference_ap:
  AP: 22.7
  AP_r: 16.3
  AP_c: 20.8
  AP_f: 25.5

outputs:
  dev_subset: "data/dev_image_ids.json"
  episodes_dev: "data/episodes/dev"
  episodes_train: "data/episodes/train"
  episodes_eval: "data/episodes/eval"
  checkpoints: "data/checkpoints"

reports:
  r0: "reports/REPORT_0_baseline.json"
  r1: "reports/REPORT_1_episodes.json"
  r2: "reports/REPORT_2_baselines_dev.json"
  r3: "reports/REPORT_3_adapter_dev.json"
  r4: "reports/REPORT_4_main.json"
  r5: "reports/REPORT_5_odinw.json"
  r6: "reports/REPORT_6_glip_main.json"

glip:
  # HF repo IDEA-Research/glip-tiny does not exist; use Grounding-DINO-tiny (same grounded API).
  backend: "transformers"
  glip_tiny_model_id: "IDEA-Research/grounding-dino-tiny"
  glip_tiny_local_dir: "weights/grounding-dino-tiny"
  native_weight: "weights/glip-native/glip_tiny_model_o365_goldg.pth"
  native_config: "third_party/GLIP/configs/pretrain/glip_Swin_T_O365_GoldG.yaml"
  native_weight_large: "weights/glip-native/glip_large_model.pth"
  native_config_large: "third_party/GLIP/configs/pretrain/glip_Swin_L.yaml"
  chunk_size: 96
  score_thresh: 0.05

owlvit:
  model_id: "google/owlvit-base-patch32"
  local_dir: "weights/owlvit-base-patch32"
  chunk_size: 96
  score_thresh: 0.05

owlvit_b16:
  model_id: "google/owlvit-base-patch16"
  local_dir: "weights/owlvit-base-patch16"
  chunk_size: 96
  score_thresh: 0.05

owlvit_l:
  model_id: "google/owlvit-large-patch14"
  local_dir: "weights/owlvit-large-patch14"
  chunk_size: 64
  score_thresh: 0.05

owlv2:
  model_id: "google/owlv2-base-patch16-ensemble"
  model_id_base_ne: "google/owlv2-base-patch16"
  model_id_large: "google/owlv2-large-patch14-ensemble"
  local_dir: "weights/owlv2-base-patch16-ensemble"
  local_dir_base_ne: "weights/owlv2-base-patch16"
  local_dir_large: "weights/owlv2-large-patch14-ensemble"
  chunk_size: 96
  score_thresh: 0.05

ultralytics_world:
  score_thresh: 0.05
  imgsz: 640

omdet_turbo:
  model_id: "omlab/omdet-turbo-swin-tiny-hf"
  local_dir: "weights/omdet-turbo-swin-tiny-hf"
  chunk_size: 40
  score_thresh: 0.05
  task: "Detect."

florence2:
  model_id_base: "microsoft/Florence-2-base"
  model_id_large: "microsoft/Florence-2-large"
  local_dir_base: "weights/florence-2-base"
  local_dir_large: "weights/florence-2-large"
  score_thresh: 0.05

gdino_base:
  chunk_size: 192
  max_text_tokens: 256
  b0_short_captions: true
  b0_image_short_edge: 640
  score_thresh: 0.05

# WSL native B0 cache (avoid /mnt/d/ JSON writes)
b0_cache_wsl: "/home/a/data/b0_cache"

detclip_v2:
  config: "third_party/DetCLIPv2/configs/detclipv2_swin_t_lvis.py"
  checkpoint: "weights/detclipv2_swin_t/detclipv2_swin_t.pth"
  chunk_size: 120
  score_thresh: 0.05
  max_text_tokens: 16
  b0_image_short_edge: 800

second_backbone:
  name: "owlvit"
  label: "OWL-ViT-B/32"

# --- VocabGuard / RobustVocab (from submission-b) ---
# VocabGuard (Paper 4) — read-only reuse of OVDeploy (Paper 2)


yolo_root: "/path/to/YOLO-World"
yolo_root_wsl: "/mnt/d/path/to/YOLO-World"

data:
  episodes_dev: "data/episodes/dev"
  episodes_train: "data/episodes/train"
  episodes_eval: "data/episodes/eval"
  b0_cache: "data/b0_cache"
  cooccur_cache: "data/cooccur_prior.json"

outputs:
  checkpoints: "data/checkpoints"
  reports: "reports"

vocabguard:
  router_delta: 5
  missing_class_extra_delta: 15
  router_cand_pool: 128
  router_cand_pool_missing: 256
  b0_hint_score_thr: 0.10
  guard_alpha: 2.0
  guard_beta: 0.3
  guard_tau: 0.5
  calib_feat_dim: 256
  calib_hidden: 128
  calib_max_classes: 64

robustvocab:
  deployment_strict: true
  b0_score_thr: 0.12
  b0_top_k: 48
  recover_delta: 8
  recover_delta_missing: 30
  cooccur_weight: 0.5
  use_cooccur: true
  two_round_probe: true
  round2_top: 12
  dual_prompt_fusion: true
  synonym_dual_prompt: false
  router_delta: 5
  missing_class_extra_delta: 15
  router_cand_pool: 128
  router_cand_pool_missing: 256
  b0_hint_score_thr: 0.10
  guard_alpha: 2.0
  guard_beta: 0.3
  guard_tau: 0.5
  glip_guard_tau: 0.42

methods:
  - VG_router
  - VG_full
  - M2_calib
  - VG_full_strict
  - RV_recover
  - RV_full
