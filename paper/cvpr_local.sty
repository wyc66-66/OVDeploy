% CVPR 2026 layout for local MiKTeX (stable). For OpenReview use cvpr_official_2026.sty.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cvpr}[2026 CVPR layout local]
\RequirePackage{times}
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{booktabs}
\RequirePackage[shortlabels,inline]{enumitem}
\setlist[itemize]{noitemsep,leftmargin=*,topsep=0em}
\setlist[enumerate]{noitemsep,leftmargin=*,topsep=0em}

\newif\ifcvprfinal
\cvprfinaltrue
\DeclareOption{review}{\cvprfinalfalse}
\DeclareOption{final}{\cvprfinaltrue}
\DeclareOption{pagenumbers}{\cvprfinalfalse}
\ProcessOptions\relax

\setlength{\textheight}{8.875in}
\setlength{\textwidth}{6.875in}
\setlength{\columnsep}{0.3125in}
\setlength{\topmargin}{0in}
\setlength{\headheight}{0in}
\setlength{\headsep}{0in}
\setlength{\parindent}{1pc}
\setlength{\oddsidemargin}{-0.1875in}
\setlength{\evensidemargin}{-0.1875in}

\ifcvprfinal\else
  \pagestyle{empty}
  \def\@maketitle{%
    \newpage\null\vskip .375in
    \begin{center}{\Large\bf\@title\par}\vspace*{24pt}
    \large Anonymous \confName~submission\\Paper ID \paperID\vspace*{12pt}
    \end{center}%
  }
\fi

\def\abstract{\centerline{\large\bf Abstract}\vspace*{10pt}\noindent\it\ignorespaces}
\def\endabstract{\vspace*{10pt}}

\renewcommand{\textfraction}{0.01}
\renewcommand{\floatpagefraction}{0.99}
\renewcommand{\topfraction}{0.99}
\renewcommand{\bottomfraction}{0.99}
